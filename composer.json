{
  "name": "solution25/sales-channel-specific-content",
  "version": "1.1.1",
  "description": "Custom plugin for per sales channel product data.",
  "type": "shopware-platform-plugin",
  "license": "MIT",
  "require": {
    "php": "^7.4 || ^8.0",
    "shopware/core": "^6.4 || ^6.5 || ^6.6 || ^6.7"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "SalesChannelSpecificContent\\": "src/"
    }
  },
  "authors": [
    {
      "name": "solution25",
      "email": "info@solution25.com",
      "homepage": "https://solution25.com/"
    }
  ],
  "extra": {
    "shopware-plugin-class": "SalesChannelSpecificContent\\SalesChannelSpecificContent",
    "label": {
      "en-GB": "Sales Channel Specific Content",
      "de-DE": "Sales Channel Specific Content"
    },
    "description": {
      "en-GB": "Plugin for defining product content per sales channel in Shopware.",
      "de-DE": "Plugin zur Definition von produktspezifischen Inhalten je Verkaufskanal in Shopware."
    },
    "manufacturerLink": {
      "en-GB": "https://solution25.com/en/home_en/",
      "de-DE": "https://solution25.com/"
    },
    "supportLink": {
      "en-GB": "https://solution25.com/en/home_en/",
      "de-DE": "https://solution25.com/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@enable-prepush"
    ],
    "post-update-cmd": [
      "@enable-prepush"
    ],
    "enable-prepush": [
      "cp ./pre-push .git/hooks/pre-push",
      "chmod +x .git/hooks/pre-push"
    ]
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    }
  }
}
